{
  "name": "thekhan-website",
  "main": "worker/index.js",
  "compatibility_date": "2025-01-01",
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "routes": [
    { "pattern": "thekhan.io/*", "zone_name": "thekhan.io" },
    { "pattern": "www.thekhan.io/*", "zone_name": "thekhan.io" }
  ]
}
